*.egg-info/
*.egg
*.whl
pip-wheel-metadata/
dist/
build/

# 🧪 Archivos grandes genéricos
*.zip
*.tar.gz
*.xlsx
*.xls

# 📊 Salidas temporales
app/data/processed/
*.log
__temp__/
temp/
tmp/

# ─────────────────────────────────────────────
# 🟢 WHITELISTED: Archivos esenciales del proyecto
# ─────────────────────────────────────────────

# Incluir los datasets del proyecto (necesarios para reproducir)
!app/data/dataset_historico_calibrado.csv
!app/data/dataset_6h.csv
!app/data/dataset_soda.csv

# Incluir el modelo entrenado y su metadata
!app/model/modelo_regresion.pkl
!app/model/meta.json
!app/model/ridge/**
!app/model/lasso/**
!app/model/per_estacion/**

# Incluir archivos JSON de configuración
!app/model/*.json

# Gemini/IDE artifacts (no subir al repo)
.gemini/
