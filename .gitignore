# 🧠 Entornos virtuales
venv/
.venv/
.env
.env.*

# ⚙️ Archivos compilados / temporales
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# 🧩 Archivos de configuración locales
.idea/
.vscode/
.DS_Store

